# ========================================
# 飞书 Todo 智能助手配置文件
# 使用说明：复制此文件为 .env 并填写实际值
# ========================================

# ========================================
# 服务配置
# ========================================
PORT=17234                          # 服务端口（避开常见占用端口 3000/8000/8080/8888）
APP_TIMEZONE=Asia/Shanghai          # 时区设置

# ========================================
# 飞书应用配置（必填）
# 获取方式：访问 https://open.feishu.cn/
# ========================================
FEISHU_APP_ID=cli_xxx              # 应用 ID
FEISHU_APP_SECRET=xxx              # 应用密钥
FEISHU_VERIFICATION_TOKEN=xxx      # 验证令牌
FEISHU_ENCRYPT_KEY=xxx             # 加密密钥（可选）

# ========================================
# 多维表格配置（必填）
# 在飞书多维表格中获取
# ========================================
FEISHU_BASE_TOKEN=HEAHbiuUFaQhE7siqzic9vjvnpf    # 多维表格 Token
FEISHU_BASE_TABLE_ID=tblXUkCfVMPg2hCv            # 表格 ID

# ========================================
# AI 配置（可选，不填则不使用 AI 功能）
# ========================================
AI_PROVIDER=openai                               # AI 供应商: openai（默认）
OPENAI_API_BASE_URL=https://api.openai.com/v1   # API 地址（支持兼容接口）
OPENAI_API_KEY=sk-xxx                            # OpenAI API Key
OPENAI_MODEL=gpt-5.4-mini                        # 使用的模型
OPENAI_VISION_MODEL=                             # 视觉模型（留空使用默认）

# 兼容接口示例：
# Ollama: http://localhost:11434/v1
# LM Studio: http://localhost:1234/v1
# 其他 OpenAI 兼容接口

# ========================================
# 功能开关
# ========================================
ENABLE_QUICK_MODE=true             # 快速模式（推荐手机端，跳过确认直接创建）
ENABLE_AI_PARSE=false              # AI 增强解析（需要 OpenAI API Key）
ENABLE_IMAGE_RECOGNITION=false     # 图片识别（需要 OpenAI API Key）
ENABLE_TODO_OPTIMIZATION=false     # 智能优化（需要 OpenAI API Key）

# ========================================
# 对话记忆配置（可选）
# ========================================
ENABLE_CHAT_MEMORY=false           # 启用对话记忆功能
FEISHU_CHAT_HISTORY_TABLE_ID=      # 对话历史表格 ID（需要在多维表格中创建）
CHAT_MEMORY_LENGTH=10              # 保留的对话轮数

# ========================================
# CLI 智能助手配置（可选）
# ========================================
LARK_CLI_PATH=D:\Feishu\cli\lark-cli.cmd    # lark-cli 路径
ENABLE_SMART_ASSISTANT=true                  # 启用智能助手功能
CLI_TIMEOUT=30000                            # CLI 执行超时时间（毫秒）
CLI_CONFIRM_ACTIONS=create,update,delete,send,approve  # 需要确认的操作类型
CLI_LOG_ENABLED=true                         # 是否记录 CLI 执行日志

# 智能助手功能说明：
# - 启用后，机器人可以通过 lark-cli 执行更多飞书操作
# - 支持：日历管理、联系人搜索、文档操作、审批管理等
# - 重要操作会要求用户确认后再执行

# ========================================
# AI Agent 智能体配置（核心功能）
# ========================================
ENABLE_AGENT=true                  # 启用 Agent 模式（多轮工具调用，推荐）
AGENT_MAX_STEPS=5                  # Agent 最大思考轮数
AGENT_SHOW_THINKING=true           # 是否显示思考过程（推送给用户）
DATA_DIR=./data                    # 本地数据库目录

# Agent 工作原理：
# - 用户消息 → AI 分析意图 → 决定调用哪些工具
# - 支持多轮：先查询再操作，自主决策
# - 工具集：list_todos / create_todo / complete_todo / delete_todo /
#          view_calendar / search_contact / search_docs / list_approvals /
#          save_memory / recall_memory / list_memories
# - 长期记忆存储在本地 SQLite 数据库（./data/feishu-bot.db）
